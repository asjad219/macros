---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

const {
  title,
  description,
  canonical,
  schema,
  robots,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-L8LJQYEKTD"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-L8LJQYEKTD');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="CalcMacros" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="CalcMacros" />
  <meta property="og:type" content="website" />
  <!-- OG Image -->
  <meta property="og:image" 
    content="https://calcmacros.com/og-image.png" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" 
    content="CalcMacros — Free Macro and TDEE Calculator" />

  <!-- Twitter Card Image -->
  <meta name="twitter:image" 
    content="https://calcmacros.com/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Schema.org JSON-LD -->
  {schema && Array.isArray(schema)
    ? schema.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    : schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
  }

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet" />



  <!-- AdSense (replace ca-pub-XXXXXXXXXXXXXXXX with your real publisher ID) -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->

  <title>{title}</title>
  
  <script is:inline>
    (function() {
      try {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
