---
// src/layouts/BlogLayout.astro
import BaseLayout from './BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';

const { frontmatter } = Astro.props;
---
<BaseLayout 
  title={frontmatter.title} 
  description={frontmatter.description} 
  canonical={`https://calcmacros.com/blog/${frontmatter.slug}`}
>
  <Header />
  <main>
    <div class="page-container">
      <article class="content-section blog-post">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-post :global(h1) {
    font: 700 40px/1.2 var(--font-sans);
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 24px;
    text-wrap: balance;
  }
  
  .blog-post :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-body);
  }

  .blog-post :global(ol) {
    list-style-type: decimal;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-body);
  }

  .blog-post :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-post :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  
  .blog-post :global(a:hover) {
    color: var(--accent-hover);
  }
  
  /* Prevent links inside specific interactive components from being underlined */
  .blog-post :global(.faq-question), .blog-post :global(.faq-question a) {
    text-decoration: none;
  }
</style>
