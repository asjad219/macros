---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/astro/Header.astro';
import Footer from '../../components/astro/Footer.astro';

const title = 'Blog — Nutrition, Macros & Fat Loss Guides | CalcMacros';
const description = 'Evidence-based guides on macros, TDEE, calorie deficits, and fat loss. No fluff. No supplements pitches. Just science-backed nutrition information.';
const canonical = 'https://calcmacros.com/blog';

const posts = [
  {
    href: '/blog/what-are-macros',
    title: 'What Are Macros? A Complete Beginner Guide',
    excerpt: 'Protein, carbs, and fat explained — what they do, how many you need, and why tracking them beats counting calories alone.',
    tag: 'Nutrition Basics',
  },
  {
    href: '/blog/what-is-tdee',
    title: 'What Is TDEE and Why Does It Matter?',
    excerpt: 'Total Daily Energy Expenditure is the number your entire nutrition plan is built around. Here is exactly what it is and how to use it.',
    tag: 'Calorie Science',
  },
  {
    href: '/blog/how-to-calculate-macros',
    title: 'How to Calculate Your Macros Step by Step',
    excerpt: 'A complete walkthrough of calculating your own macros from scratch — including which formulas to use and common mistakes to avoid.',
    tag: 'Macros Guide',
  },
  {
    href: '/blog/calorie-deficit-explained',
    title: 'Calorie Deficit Explained — How Big Should Yours Be?',
    excerpt: 'The science of calorie deficits: why too large a deficit backfires, what the research says about optimal deficit size, and how to adjust over time.',
    tag: 'Fat Loss',
  },
  {
    href: '/blog/body-fat-percentage-calculator-guide',
    title: "Body Fat Percentage Calculator: What's a Healthy Range? (2026 Guide)",
    excerpt: 'Calculate your body fat percentage instantly with our free calculator. Learn healthy ranges by age and gender, measurement methods, and how to lower body fat safely.',
    tag: 'Calculators',
  },
  {
    href: '/blog/calorie-burn-calculator-how-many-calories-do-you-burn-a-day',
    title: 'How Many Calories Do You Burn a Day?',
    excerpt: 'Free calorie burn calculator using the Mifflin-St Jeor formula. Learn your BMR, TDEE, and exact daily calorie burn.',
    tag: 'Calculators',
  },
  {
    href: '/blog/ideal-weight-calculator-guide',
    title: "Ideal Weight Calculator: What Should You Actually Weigh?",
    excerpt: 'Find your healthy weight range by height, age, and frame size using 4 medical formulas — and why ideal weight is more nuanced than a chart.',
    tag: 'Calculators',
  },
  {
    href: '/blog/lean-body-mass-calculator-guide',
    title: "Lean Body Mass Calculator: What It Means and Why It Matters",
    excerpt: 'Free lean body mass calculator using 3 medical formulas. Learn what LBM means, how it differs from muscle mass, and how to use it to guide training and nutrition.',
    tag: 'Calculators',
  },
  {
    href: '/blog/water-intake-calculator-guide',
    title: "Water Intake Calculator: How Much Water Should You Drink Daily?",
    excerpt: 'Free water intake calculator based on weight, activity level, and climate. Learn how much water you actually need daily and signs of dehydration to watch for.',
    tag: 'Calculators',
  },
];
---

<BaseLayout {title} {description} {canonical}>
  <Header />
  <main>
    <div class="page-container">
      <section class="hero">
        <h1>Nutrition &amp; Macro Guides</h1>
        <p>Evidence-based articles on macros, TDEE, fat loss, and body composition. No fluff.</p>
      </section>

      <div class="blog-grid">
        {posts.map(post => (
          <a href={post.href} class="blog-card">
            <span class="blog-tag">{post.tag}</span>
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
