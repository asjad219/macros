---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';

const title = 'Page Not Found | CalcMacros';
const description = 'The page you are looking for does not exist.';
const canonical = 'https://calcmacros.com/404';
---

<BaseLayout {title} {description} {canonical}>
  <Header />
  <main class="page-container" style="text-align: center; padding: 100px 20px; min-height: 60vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <h1 style="font-size: 4rem; color: var(--primary); margin-bottom: 16px;">404</h1>
    <h2>Page Not Found</h2>
    <p style="margin-bottom: 32px; color: var(--text-secondary); max-width: 500px;">Sorry, we couldn't find the page you're looking for. It might have been moved or deleted.</p>
    <a href="/" class="btn btn-primary" style="display: inline-block;">Return Home</a>
  </main>
  <Footer />
</BaseLayout>
